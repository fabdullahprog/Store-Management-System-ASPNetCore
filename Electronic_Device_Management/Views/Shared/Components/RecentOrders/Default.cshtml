@model IEnumerable<Electronic_Device_Management.Models.Order>

@if (Model != null && Model.Any())
{
    <div class="row g-3">
        @foreach (var order in Model)
        {
            <div class="col-md-6 col-xl-4">
                <div class="card h-100 border-0 shadow-sm hover-shadow transition-all" style="border-left: 4px solid var(--gold) !important;">
                    <div class="card-body p-3">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div class="bg-light rounded-circle p-2 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                <i class="fas fa-shopping-bag text-primary"></i>
                            </div>
                            <span class="badge rounded-pill bg-light text-dark border">#@order.OrderId</span>
                        </div>

                        <h6 class="card-title mb-1 fw-bold text-dark">
                            @(order.Customer?.CustomerName ?? "Walking Customer")
                        </h6>

                        <div class="d-flex justify-content-between align-items-end mt-3">
                            <div>
                                <p class="text-muted small mb-0">
                                    <i class="far fa-calendar-alt me-1"></i> @order.OrderDate.ToString("MMM dd, yyyy")
                                </p>
                            </div>
                            <div class="text-end">
                                <h5 class="mb-0 fw-bold text-success">$@order.TotalAmount.ToString("N2")</h5>
                            </div>
                        </div>

                        <hr class="my-2 opacity-25">

                        <a href="@Url.Action("Details", "Order", new { id = order.OrderId })"
                           class="btn btn-sm btn-outline-primary w-100 border-0 bg-light text-primary fw-600 mt-1">
                            View Details <i class="fas fa-arrow-right ms-1 small"></i>
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="text-center py-5 bg-light rounded-3">
        <i class="fas fa-receipt fa-3x text-muted mb-3"></i>
        <p class="text-muted">No orders found in the system yet.</p>
    </div>
}

<style>
    .hover-shadow:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }

    .transition-all {
        transition: all 0.3s ease;
    }

    .fw-600 {
        font-weight: 600;
    }
</style>
