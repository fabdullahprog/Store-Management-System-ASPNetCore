@{
    ViewData["Title"] = "Access Denied";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-ban"></i> Access Denied
                    </h4>
                </div>
                <div class="card-body text-center">
                    <div class="mb-4">
                        <i class="fas fa-exclamation-triangle text-danger" style="font-size: 80px;"></i>
                    </div>
                    
                    <h3 class="text-danger mb-3">403 - Forbidden</h3>
                    
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-warning">
                            <strong>@TempData["ErrorMessage"]</strong>
                        </div>
                    }
                    else
                    {
                        <p class="lead">You do not have permission to access this resource.</p>
                    }
                    
                    <p class="text-muted mb-4">
                        If you believe this is an error, please contact your administrator to request the necessary permissions.
                    </p>
                    
                    <div class="mt-4">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                            <i class="fas fa-home"></i> Go to Home
                        </a>
                        <a href="javascript:history.back()" class="btn btn-secondary">
                            <i class="fas fa-arrow-left"></i> Go Back
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
