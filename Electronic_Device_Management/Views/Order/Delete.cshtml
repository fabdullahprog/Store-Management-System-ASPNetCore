@model Electronic_Device_Management.Models.ViewModels.OrderMasterViewModel

@{
    ViewBag.Title = "Delete Order";
}

<div class="container mt-4">
    <h2><i class="fas fa-trash text-danger"></i> Delete Order #@Model.OrderId</h2>
    <hr />

    <div class="alert alert-danger">
        <h4><i class="fas fa-exclamation-triangle"></i> Are you sure you want to delete this order?</h4>
    </div>

    <div class="form-container">
        <div class="row">
            <div class="col-md-6">
                <h5>Customer Information</h5>
                <dl class="row">
                    <dt class="col-sm-5">@Html.DisplayNameFor(model => model.CustomerName)</dt>
                    <dd class="col-sm-7">@Html.DisplayFor(model => model.CustomerName)</dd>

                    <dt class="col-sm-5">@Html.DisplayNameFor(model => model.ContactNumber)</dt>
                    <dd class="col-sm-7">@Html.DisplayFor(model => model.ContactNumber)</dd>

                    <dt class="col-sm-5">@Html.DisplayNameFor(model => model.ContactAddress)</dt>
                    <dd class="col-sm-7">@Html.DisplayFor(model => model.ContactAddress)</dd>
                </dl>
            </div>
            <div class="col-md-6">
                <h5>Order Information</h5>
                <dl class="row">
                    <dt class="col-sm-5">Order Date</dt>
                    <dd class="col-sm-7">@Model.OrderDate.ToString("dd MMM yyyy")</dd>

                    <dt class="col-sm-5">Total Amount</dt>
                    <dd class="col-sm-7"><strong>@Model.TotalAmount.ToString("N2")</strong></dd>

                    <dt class="col-sm-5">Number of Items</dt>
                    <dd class="col-sm-7">@Model.OrderDetailsList.Count</dd>
                </dl>
            </div>
        </div>

        <h5 class="mt-4">Order Items</h5>
        <div class="table-responsive">
            <table class="table table-bordered table-sm">
                <thead class="table-light">
                    <tr>
                        <th>Category</th>
                        <th>Product</th>
                        <th>Quantity</th>
                        <th>Unit</th>
                        <th>Unit Price</th>
                        <th>Amount</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.OrderDetailsList)
                    {
                        <tr>
                            <td>@item.CategoryName</td>
                            <td>@item.ProductName</td>
                            <td>@item.OrderQuantity</td>
                            <td>@item.OrderUnit</td>
                            <td>@item.UnitPrice.ToString("N2")</td>
                            <td>@item.Amount.ToString("N2")</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <th colspan="5" class="text-end">Total:</th>
                        <th>@Model.TotalAmount.ToString("N2")</th>
                    </tr>
                </tfoot>
            </table>
        </div>

        <form asp-action="Delete" method="post" class="mt-4">
            <input type="hidden" asp-for="OrderId" />

            <div class="form-group">
                <button type="submit" class="btn btn-danger">
                    <i class="fas fa-trash"></i> Confirm Delete
                </button>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Back to List
                </a>
            </div>
        </form>
    </div>
</div>

