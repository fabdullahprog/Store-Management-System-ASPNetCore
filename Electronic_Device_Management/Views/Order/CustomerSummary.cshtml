@model IEnumerable<Electronic_Device_Management.Models.ViewModels.CustomerOrderSummaryViewModel>

@{
    ViewBag.Title = "Customer Summary";
}

<div class="container mt-4">
    <h2><i class="fas fa-users"></i> Customer Order Summary</h2>
    <hr />

    @if (!Model.Any())
    {
        <div class="alert alert-warning">
            <i class="fas fa-exclamation-triangle"></i> No customer data found.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-bordered table-hover">
                <thead>
                    <tr>
                        <th>Customer Name</th>
                        <th>Contact Number</th>
                        <th>Contact Address</th>
                        <th>Total Orders</th>
                        <th>Total Spent</th>
                        <th>Last Order Date</th>
                       
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.CustomerName</td>
                            <td>@item.ContactNumber</td>
                            <td>@item.ContactAddress</td>
                            <td>
                                <span class="badge bg-info">@item.TotalOrders</span>
                            </td>
                            <td>
                                <strong>@item.TotalSpent.ToString("N2")</strong>
                            </td>
                            <td>
                                @(item.LastOrderDate?.ToString("dd MMM yyyy") ?? "N/A")
                            </td>
                          
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <div class="mt-3">
        <a asp-action="Index" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Back to Orders
        </a>
    </div>
</div>

