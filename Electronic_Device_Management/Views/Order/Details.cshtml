@model Electronic_Device_Management.Models.ViewModels.OrderMasterViewModel

@{
    ViewBag.Title = "Order Details";

    // Function to convert number to words (simplified for display)
    Func<decimal, string> NumberToWords = amount =>
    {
        // Simple version for demo, can be replaced with proper library
        return amount.ToString("N2") + " Taka Only";
    };
}

<div class="container mt-4" id="printArea">
    <!-- Header / Company Info -->
        <div class="row mb-4">
            <div class="col-6">
                <h4>Electronics shop</h4>
                <p> Electronics device</p>
                <p>123 , ctg, bangladesh</p>
                <p>Phone: +880 1234 | Email: info@electronics.com</p>
            </div>
      <div class="col-6 text-end">
            <h2><i class="fas fa-file-invoice"></i> Invoice</h2>
            <p><strong>Invoice #@Model.OrderId</strong></p>
            <p><strong>Date:</strong> @Model.OrderDate.ToString("dd MMM yyyy")</p>
            <p><strong>Due Date:</strong> @Model.OrderDate.AddDays(7).ToString("dd MMM yyyy")</p>
        </div>
    </div>

    <hr />

    <!-- Customer & Order Info -->
    <div class="row mb-4">
        <div class="col-md-6">
            <h5>Bill To:</h5>
            <p>
                <strong>@Model.CustomerName</strong><br />
                @Model.ContactAddress<br />
                @Model.ContactNumber
            </p>
        </div>
        <div class="col-md-6 text-end">
            <h5>Order Details:</h5>
            <p>
                <strong>Order ID:</strong> @Model.OrderId<br />
                <strong>Items:</strong> @Model.OrderDetailsList.Count<br />
                <strong>Subtotal:</strong> <span class="text-success">@Model.TotalAmount.ToString("N2")</span><br />
                <strong>Total (in words):</strong> <em>@NumberToWords(Model.TotalAmount)</em>
            </p>
        </div>
    </div>

    <!-- Order Items Table -->
    <div class="table-responsive mb-4">
        <table class="table table-bordered table-striped">
            <thead class="table-light">
                <tr>
                    <th>Category</th>
                    <th>Product</th>
                    <th class="text-end">Quantity</th>
                    <th>Unit</th>
                    <th class="text-end">Unit Price</th>
                    <th class="text-end">Amount</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.OrderDetailsList)
                {
                    <tr>
                        <td>@item.CategoryName</td>
                        <td>@item.ProductName</td>
                        <td class="text-end">@item.OrderQuantity</td>
                        <td>@item.OrderUnit</td>
                        <td class="text-end">@item.UnitPrice.ToString("N2")</td>
                        <td class="text-end">@item.Amount.ToString("N2")</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr class="table-success">
                    <th colspan="5" class="text-end">Total Amount:</th>
                    <th class="text-end">@Model.TotalAmount.ToString("N2")</th>
                </tr>
            </tfoot>
        </table>
    </div>

    <!-- Footer / Notes -->
    <div class="row mb-4">
        <div class="col-6">
            <p><strong>Thank you!</strong></p>
        </div>
        <div class="col-6 text-end">
            <p><strong>Signature</strong></p>
            <div style="border-top:1px solid #000; width:150px; margin-left:auto;"></div>
        </div>
    </div>

    <!-- Action Buttons -->
    <div class="mb-4">
        <button class="btn btn-primary" onclick="window.print()">
            <i class="fas fa-print"></i> Print Invoice
        </button>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Back to Orders
        </a>
        <a asp-action="Edit" asp-route-id="@Model.OrderId" class="btn btn-warning">
            <i class="fas fa-edit"></i> Edit
        </a>
    </div>
</div>

<!-- Print Styles -->
<style>
    @@media print {
        body *

    {
        visibility: hidden;
    }

    #printArea, #printArea * {
        visibility: visible;
    }

    #printArea {
        position: absolute;
        left: 0;
        top: 0;
        width: 100%;
    }

    .btn {
        display: none !important;
    }

    table {
        page-break-inside: auto;
    }

    tr {
        page-break-inside: avoid;
        page-break-after: auto;
    }

    th, td {
        font-size: 12pt;
    }

    }

    /* Styling for screen */
    #printArea {
        background: #fff;
        padding: 1.5rem;
        border: 1px solid #ddd;
        box-shadow: 0 0 10px rgba(0,0,0,0.1);
    }

    h2, h4, h5 {
        margin-bottom: 0.5rem;
    }

    table th, table td {
        vertical-align: middle !important;
    }

    .table-striped tbody tr:nth-of-type(odd) {
        background-color: rgba(0,0,0,.05);
    }
</style>

