@model Electronic_Device_Management.Models.ViewModels.CustomerOrderSummaryViewModel

@{
    ViewBag.Title = "Customer Order Details";
}

<div class="container mt-4">
    <h2><i class="fas fa-user"></i> @Model.CustomerName - Order History</h2>
    <hr />

    <div class="card mb-4">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="fas fa-info-circle"></i> Customer Information</h5>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-4">
                    <strong>Contact Number:</strong> @Model.ContactNumber
                </div>
                <div class="col-md-4">
                    <strong>Address:</strong> @Model.ContactAddress
                </div>
                <div class="col-md-4">
                    <strong>Total Orders:</strong> <span class="badge badge-info">@Model.TotalOrders</span><br/>
                    <strong>Total Spent:</strong> <span class="text-success">@Model.TotalSpent.ToString("N2")</span>
                </div>
            </div>
        </div>
    </div>

    <h4><i class="fas fa-file-invoice"></i> Orders</h4>
    <div class="table-responsive mb-4">
        <table class="table table-striped table-bordered">
            <thead>
                <tr>
                    <th>Order ID</th>
                    <th>Order Date</th>
                    <th>Total Amount</th>
                    <th>Number of Items</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model.Orders)
                {
                    <tr>
                        <td>@order.OrderId</td>
                        <td>@order.OrderDate.ToString("dd MMM yyyy")</td>
                        <td>@order.TotalAmount.ToString("N2")</td>
                        <td>@order.NumberOfItems</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@order.OrderId" class="btn btn-sm btn-info">
                                <i class="fas fa-eye"></i> Details
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <h4><i class="fas fa-box"></i> All Order Items</h4>
    <div class="table-responsive">
        <table class="table table-bordered table-sm">
            <thead class="table-light">
                <tr>
                    <th>Order ID</th>
                    <th>Category</th>
                    <th>Product</th>
                    <th>Quantity</th>
                    <th>Unit</th>
                    <th>Unit Price</th>
                    <th>Amount</th>
                    <th>Current Stock</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.OrderDetails)
                {
                    <tr>
                        <td>@item.OrderId</td>
                        <td>@item.CategoryName</td>
                        <td>@item.ProductName</td>
                        <td>@item.OrderQuantity</td>
                        <td>@item.OrderUnit</td>
                        <td>@item.UnitPrice.ToString("N2")</td>
                        <td>৳@item.Amount.ToString("N2")</td>
                        <td>
                            @if (item.CurrentStock <= 5)
                            {
                                <span class="badge badge-danger">@item.CurrentStock</span>
                            }
                            else
                            {
                                <span class="badge badge-success">@item.CurrentStock</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="mt-4">
        <a asp-action="CustomerSummary" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Back to Customer Summary
        </a>
    </div>
</div>

