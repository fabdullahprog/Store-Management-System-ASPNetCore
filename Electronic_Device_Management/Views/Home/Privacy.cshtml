@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container mt-5 mb-5" style="max-width: 900px;">
    <div style="text-align: center; margin-bottom: 3rem;">
        <div class="section-title">
            <h1 style="font-size: 2.5rem;">Privacy Policy</h1>
        </div>
        <p style="color: #666; font-size: 1rem;">FragranceHub - Premium Perfumes</p>
    </div>

    <div class="card" style="border: none; border-top: 4px solid var(--primary-gold);">
        <div class="card-body" style="padding: 2.5rem;">
            <h3 style="color: var(--primary-dark); margin-top: 2rem; margin-bottom: 1rem;">
                <i class="fas fa-shield-alt" style="color: var(--primary-gold); margin-right: 0.5rem;"></i>
                Your Privacy Matters to Us
            </h3>
            <p style="color: #666; line-height: 1.8;">
                At FragranceHub, we are committed to protecting your privacy and ensuring you have a positive experience on our website. 
                This Privacy Policy explains how we collect, use, and safeguard your information.
            </p>

            <h4 style="color: var(--primary-dark); margin-top: 2rem; margin-bottom: 1rem;">
                <i class="fas fa-database" style="color: var(--primary-gold); margin-right: 0.5rem;"></i>
                Information We Collect
            </h4>
            <ul style="color: #666; line-height: 1.8;">
                <li>Personal identification information (name, email, phone number, address)</li>
                <li>Payment information for processing orders</li>
                <li>Browsing history and preferences on our website</li>
                <li>Device information and IP addresses</li>
            </ul>

            <h4 style="color: var(--primary-dark); margin-top: 2rem; margin-bottom: 1rem;">
                <i class="fas fa-cog" style="color: var(--primary-gold); margin-right: 0.5rem;"></i>
                How We Use Your Information
            </h4>
            <ul style="color: #666; line-height: 1.8;">
                <li>Process and deliver your perfume orders</li>
                <li>Improve our website and services</li>
                <li>Send you promotional updates (with your consent)</li>
                <li>Provide customer support and assistance</li>
                <li>Prevent fraud and ensure security</li>
            </ul>

            <h4 style="color: var(--primary-dark); margin-top: 2rem; margin-bottom: 1rem;">
                <i class="fas fa-lock" style="color: var(--primary-gold); margin-right: 0.5rem;"></i>
                Data Security
            </h4>
            <p style="color: #666; line-height: 1.8;">
                We implement industry-standard security measures to protect your information from unauthorized access, alteration, 
                disclosure, or destruction. However, no method of transmission over the internet is 100% secure.
            </p>

            <h4 style="color: var(--primary-dark); margin-top: 2rem; margin-bottom: 1rem;">
                <i class="fas fa-share-alt" style="color: var(--primary-gold); margin-right: 0.5rem;"></i>
                Third-Party Sharing
            </h4>
            <p style="color: #666; line-height: 1.8;">
                We do not sell or share your personal information with third parties without your consent, except when required 
                by law or to provide services you've requested (such as payment processing).
            </p>

            <h4 style="color: var(--primary-dark); margin-top: 2rem; margin-bottom: 1rem;">
                <i class="fas fa-user-check" style="color: var(--primary-gold); margin-right: 0.5rem;"></i>
                Your Rights
            </h4>
            <p style="color: #666; line-height: 1.8;">
                You have the right to access, update, or delete your personal information at any time. You can manage your preferences 
                in your account settings or contact us for assistance.
            </p>

            <h4 style="color: var(--primary-dark); margin-top: 2rem; margin-bottom: 1rem;">
                <i class="fas fa-envelope" style="color: var(--primary-gold); margin-right: 0.5rem;"></i>
                Contact Us
            </h4>
            <p style="color: #666; line-height: 1.8;">
                If you have any questions about this Privacy Policy or our privacy practices, please contact us at 
                <strong>privacy@fragrancehub.com</strong> or through our website contact form.
            </p>

            <p style="color: #999; margin-top: 2rem; font-size: 0.9rem; border-top: 1px solid var(--border-light); padding-top: 1.5rem;">
                <i class="fas fa-info-circle"></i> Last updated: February 2026. This policy may be updated periodically without notice.
            </p>
        </div>
    </div>

    <div style="text-align: center; margin-top: 3rem;">
        <a asp-area="" asp-controller="Home" asp-action="Index" class="btn btn-primary">
            <i class="fas fa-home"></i> Back to Home
        </a>
    </div>
</div>
