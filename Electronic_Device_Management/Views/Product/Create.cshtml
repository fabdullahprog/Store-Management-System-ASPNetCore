@model Electronic_Device_Management.Models.ViewModels.ProductViewModel

@{
    ViewBag.Title = "Create Product";
}

<div class="container mt-4">
    <h2><i class="fas fa-plus-circle"></i> Create Product</h2>
    <hr />

    <div class="form-container">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group row">
                <label asp-for="ProductName" class="control-label col-md-3"></label>
                <div class="col-md-9">
                    <input asp-for="ProductName" class="form-control" placeholder="Enter product name" />
                    <span asp-validation-for="ProductName" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group row">
                <label asp-for="ProductCategoryId" class="control-label col-md-3"></label>
                <div class="col-md-9">
                    <select asp-for="ProductCategoryId" asp-items="ViewBag.ProductCategoryId" class="form-select">
                        <option value="">-- Select Category --</option>
                    </select>
                    <span asp-validation-for="ProductCategoryId" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group row">
                <label asp-for="Unit" class="control-label col-md-3"></label>
                <div class="col-md-9">
                    <select asp-for="Unit" asp-items="ViewBag.Units" class="form-select">
                        <option value="">-- Select Unit --</option>
                    </select>
                    <span asp-validation-for="Unit" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group row">
                <label asp-for="UnitPrice" class="control-label col-md-3"></label>
                <div class="col-md-9">
                    <input asp-for="UnitPrice" class="form-control" type="number" step="0.01" placeholder="0.00" />
                    <span asp-validation-for="UnitPrice" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group row">
                <label asp-for="AvailableQuantity" class="control-label col-md-3"></label>
                <div class="col-md-9">
                    <input asp-for="AvailableQuantity" class="form-control" type="number" placeholder="0" />
                    <span asp-validation-for="AvailableQuantity" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group row">
                <label asp-for="ImageFile" class="control-label col-md-3"></label>
                <div class="col-md-9">
                    <input asp-for="ImageFile" class="form-control" type="file" accept="image/*" />
                    <span asp-validation-for="ImageFile" class="text-danger"></span>
                    <small class="form-text text-muted">Upload product image (optional)</small>
                </div>
            </div>

            <div class="form-group row">
                <div class="col-md-9 offset-md-3">
                    <div class="form-check">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" checked />
                        <label asp-for="IsActive" class="form-check-label"></label>
                    </div>
                </div>
            </div>

            <div class="form-group row">
                <div class="col-md-9 offset-md-3">
                    <button type="submit" class="btn btn-success">
                        <i class="fas fa-save"></i> Create
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Back to List
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

