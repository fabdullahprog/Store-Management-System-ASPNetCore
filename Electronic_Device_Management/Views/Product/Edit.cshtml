@model Electronic_Device_Management.Models.ViewModels.ProductViewModel

@{
    ViewBag.Title = "Edit Product";
}

<div class="container mt-4">
    <h2><i class="fas fa-edit"></i> Edit Product</h2>
    <hr />

    <div class="form-container">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="ProductId" />
            <input type="hidden" asp-for="ProductImage" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group row">
                <label asp-for="ProductName" class="control-label col-md-3"></label>
                <div class="col-md-9">
                    <input asp-for="ProductName" class="form-control" />
                    <span asp-validation-for="ProductName" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group row">
                <label asp-for="ProductCategoryId" class="control-label col-md-3"></label>
                <div class="col-md-9">
                    <select asp-for="ProductCategoryId" asp-items="ViewBag.ProductCategoryId" class="form-select">
                        <option value="">-- Select Category --</option>
                    </select>
                    <span asp-validation-for="ProductCategoryId" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group row">
                <label asp-for="Unit" class="control-label col-md-3"></label>
                <div class="col-md-9">
                    <select asp-for="Unit" asp-items="ViewBag.Units" class="form-select">
                        <option value="">-- Select Unit --</option>
                    </select>
                    <span asp-validation-for="Unit" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group row">
                <label asp-for="UnitPrice" class="control-label col-md-3"></label>
                <div class="col-md-9">
                    <input asp-for="UnitPrice" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="UnitPrice" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group row">
                <label asp-for="AvailableQuantity" class="control-label col-md-3"></label>
                <div class="col-md-9">
                    <input asp-for="AvailableQuantity" class="form-control" type="number" />
                    <span asp-validation-for="AvailableQuantity" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group row">
                <label class="control-label col-md-3">Current Image</label>
                <div class="col-md-9">
                    @if (!string.IsNullOrEmpty(Model.ProductImage))
                    {
                        <img src="~/images/@Model.ProductImage" alt="@Model.ProductName" style="max-width: 200px; height: auto;" class="img-thumbnail mb-2" />
                    }
                    else
                    {
                        <p class="text-muted">No image uploaded</p>
                    }
                </div>
            </div>

            <div class="form-group row">
                <label asp-for="ImageFile" class="control-label col-md-3"></label>
                <div class="col-md-9">
                    <input asp-for="ImageFile" class="form-control" type="file" accept="image/*" />
                    <span asp-validation-for="ImageFile" class="text-danger"></span>
                    <small class="form-text text-muted">Upload new image to replace current (optional)</small>
                </div>
            </div>

            <div class="form-group row">
                <div class="col-md-9 offset-md-3">
                    <div class="form-check">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                        <label asp-for="IsActive" class="form-check-label"></label>
                    </div>
                </div>
            </div>

            <div class="form-group row">
                <div class="col-md-9 offset-md-3">
                    <button type="submit" class="btn btn-success">
                        <i class="fas fa-save"></i> Save Changes
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Back to List
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

