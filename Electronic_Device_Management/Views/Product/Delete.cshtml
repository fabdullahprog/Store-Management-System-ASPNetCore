@model Electronic_Device_Management.Models.ViewModels.ProductViewModel

@{
    ViewBag.Title = "Delete Product";
}

<div class="container mt-4">
    <h2><i class="fas fa-trash text-danger"></i> Delete Product</h2>
    <hr />

    <div class="alert alert-danger">
        <h4><i class="fas fa-exclamation-triangle"></i> Are you sure you want to delete this product?</h4>
    </div>

    <div class="form-container">
        <div class="row">
            <div class="col-md-4">
                @if (!string.IsNullOrEmpty(Model.ProductImage))
                {
                    <img src="~/images/@Model.ProductImage" alt="@Model.ProductName" class="img-fluid rounded" />
                }
                else
                {
                    <div class="text-center p-5 bg-light rounded">
                        <i class="fas fa-image fa-4x text-muted"></i>
                        <p class="mt-2 text-muted">No Image</p>
                    </div>
                }
            </div>
            <div class="col-md-8">
                <dl class="row">
                    <dt class="col-sm-4">@Html.DisplayNameFor(model => model.ProductName)</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(model => model.ProductName)</dd>

                    <dt class="col-sm-4">@Html.DisplayNameFor(model => model.CategoryName)</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(model => model.CategoryName)</dd>

                    <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Unit)</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(model => model.Unit)</dd>

                    <dt class="col-sm-4">@Html.DisplayNameFor(model => model.UnitPrice)</dt>
                    <dd class="col-sm-8">৳@Model.UnitPrice.ToString("N2")</dd>

                    <dt class="col-sm-4">@Html.DisplayNameFor(model => model.AvailableQuantity)</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(model => model.AvailableQuantity)</dd>

                    <dt class="col-sm-4">@Html.DisplayNameFor(model => model.IsActive)</dt>
                    <dd class="col-sm-8">
                        @if (Model.IsActive)
                        {
                            <span class="badge badge-success">Active</span>
                        }
                        else
                        {
                            <span class="badge badge-danger">Inactive</span>
                        }
                    </dd>
                </dl>
            </div>
        </div>

        <form asp-action="Delete" method="post" class="mt-4">
            <input type="hidden" asp-for="ProductId" />

            <div class="form-group">
                <button type="submit" class="btn btn-danger">
                    <i class="fas fa-trash"></i> Confirm Delete
                </button>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Back to List
                </a>
            </div>
        </form>
    </div>
</div>

