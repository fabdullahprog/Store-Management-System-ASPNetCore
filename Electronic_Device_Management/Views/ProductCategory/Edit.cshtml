@model Electronic_Device_Management.Models.ViewModels.ProductCategoryViewModel

@{
    ViewBag.Title = "Edit Product Category";
}

<div class="container mt-4">
    <h2><i class="fas fa-edit"></i> Edit Product Category</h2>
    <hr />

    <div class="form-container">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="ProductCategoryId" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group row">
                <label asp-for="CategoryName" class="control-label col-md-3"></label>
                <div class="col-md-9">
                    <input asp-for="CategoryName" class="form-control" />
                    <span asp-validation-for="CategoryName" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group row">
                <label asp-for="CategoryDescription" class="control-label col-md-3"></label>
                <div class="col-md-9">
                    <textarea asp-for="CategoryDescription" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="CategoryDescription" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group row">
                <div class="col-md-9 offset-md-3">
                    <button type="submit" class="btn btn-success">
                        <i class="fas fa-save"></i> Save Changes
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Back to List
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

