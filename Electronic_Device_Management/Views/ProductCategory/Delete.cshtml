@model Electronic_Device_Management.Models.ViewModels.ProductCategoryViewModel

@{
    ViewBag.Title = "Delete Product Category";
}

<div class="container mt-4">
    <h2><i class="fas fa-trash text-danger"></i> Delete Product Category</h2>
    <hr />

    <div class="alert alert-danger">
        <h4><i class="fas fa-exclamation-triangle"></i> Are you sure you want to delete this category?</h4>
    </div>

    <div class="form-container">
        <dl class="row">
            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.CategoryName)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.CategoryName)</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.CategoryDescription)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.CategoryDescription)</dd>
        </dl>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="ProductCategoryId" />

            <div class="form-group">
                <button type="submit" class="btn btn-danger">
                    <i class="fas fa-trash"></i> Confirm Delete
                </button>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Back to List
                </a>
            </div>
        </form>
    </div>
</div>

